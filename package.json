{
  "name": "barberpro-next",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build:legacy-script": "node scripts/build-legacy-script.cjs",
    "normalize:legacy-encoding": "node scripts/normalize-legacy-utf8.cjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "env:check:prod": "node scripts/check-prod-env.cjs",
    "check:migrations": "node scripts/check-migrations.cjs",
    "supabase:db:push": "npx.cmd supabase db push",
    "supabase:db:reset": "npx.cmd supabase db reset",
    "cron:billing:retry": "node scripts/trigger-cron.cjs /api/cron/billing-retry",
    "cron:billing:reconcile": "node scripts/trigger-cron.cjs /api/cron/billing-reconcile",
    "cron:privacy:process": "node scripts/trigger-cron.cjs /api/cron/privacy-process",
    "cron:appointments:status": "node scripts/trigger-cron.cjs /api/cron/appointments-status",
    "check:parity": "node scripts/check-parity.cjs",
    "check:agenda": "node scripts/check-agenda-core.cjs",
    "test": "node --test tests/*.test.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:agenda:full": "node scripts/run-agenda-blindada.cjs",
    "check:supabase": "node scripts/check-supabase-readiness.cjs",
    "check:go-live": "node scripts/check-go-live.cjs",
    "env:check:matrix": "node scripts/check-env-matrix.cjs",
    "secrets:sync:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-prod-secrets.ps1 -EnvFile .env.prod",
    "user:create:barber": "node scripts/create-test-barber.cjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.27",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "http-server": "^14.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "5.5.4"
  }
}
