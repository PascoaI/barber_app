# Client
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server/API (required for app/api/* write-paths)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: force boot-time env validation outside Vercel production
ENFORCE_BOOT_ENV=false
APP_BASE_DOMAIN=example.com
DEFAULT_TENANT_SLUG=barbearia-xz
ENABLE_LEGACY_HTML_REWRITES=true
ENABLE_LEGACY_SLUG_REDIRECTS=true
ENABLE_LEGACY_PARITY_CHECK=true

# Stripe (real billing)
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
BILLING_GRACE_DAYS=3

# Cron/auth
CRON_SECRET=change_me

# Distributed rate limit / brute-force protection (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://xxxx-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=upstash_token_here

# Alerts/observability
OPS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
